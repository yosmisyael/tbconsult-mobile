# Application
ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Supabase PostgreSQL Database
# Replace with your actual Supabase connection string.
# IMPORTANT: Ensure the prefix is `postgresql+asyncpg://` instead of `postgresql://`
DATABASE_URL=postgresql+asyncpg://postgres.your_project_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# Redis (self-hosted in Docker)
REDIS_URL=redis://redis:6379/0

# DigitalOcean GenAI Model
DIGITALOCEAN_API_KEY=your_digitalocean_model_access_key
DIGITALOCEAN_BASE_URL=https://inference.do-ai.run/v1/

LLM_MODEL_ID=router:tbshield
EMBED_MODEL_ID=bge-m3

# Cohere Reranker
COHERE_API_KEY=

# Web Search (Tavily - fallback only)
TAVILY_API_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Timeouts (ms)
DIGITALOCEAN_TIMEOUT_MS=15000
WEB_SEARCH_TIMEOUT_MS=1500
PGVECTOR_TIMEOUT_MS=2000